#!/bin/zsh
set -euo pipefail

osascript <<'APPLESCRIPT'
set layoutVariableName to "user.localToolsLayout"
set slotVariableName to "user.localToolsSlot"
set resetCount to 0
set resetErrors to {}
set quadLaptopUsedSlots to {}
set quadUsedSlots to {}
set stackUsedSlots to {}
set stackLaptopUsedSlots to {}
set quadLaptopUntaggedWindows to {}
set quadUntaggedWindows to {}
set stackUntaggedWindows to {}
set stackLaptopUntaggedWindows to {}
set quadLaptopTaggedWindows to {}
set stackLaptopTaggedWindows to {}

tell application id "com.googlecode.iterm2"
	repeat with layoutWindow in windows
		try
			set windowSession to current session of layoutWindow
			set layoutName to my sessionVariable(windowSession, layoutVariableName)
			set slotName to my sessionVariable(windowSession, slotVariableName)
			set sessionProfileName to profile name of windowSession

			if my isKnownSlot(layoutName, slotName) then
				if layoutName is "quad-laptop" then
					set end of quadLaptopTaggedWindows to {windowRef:contents of layoutWindow, slotName:slotName}
					set quadLaptopUsedSlots to my addSlotIfMissing(quadLaptopUsedSlots, slotName)
				else if layoutName is "quad-left" then
					set bounds of layoutWindow to my boundsFor(layoutName, slotName)
					set quadUsedSlots to my addSlotIfMissing(quadUsedSlots, slotName)
					set resetCount to resetCount + 1
				else if layoutName is "stack-left" then
					set bounds of layoutWindow to my boundsFor(layoutName, slotName)
					set stackUsedSlots to my addSlotIfMissing(stackUsedSlots, slotName)
					set resetCount to resetCount + 1
				else if layoutName is "stack-laptop" then
					set end of stackLaptopTaggedWindows to {windowRef:contents of layoutWindow, slotName:slotName}
					set stackLaptopUsedSlots to my addSlotIfMissing(stackLaptopUsedSlots, slotName)
				end if
			else if sessionProfileName is "Quad Laptop" then
				set end of quadLaptopUntaggedWindows to contents of layoutWindow
			else if sessionProfileName is "Quad Left" then
				set end of quadUntaggedWindows to contents of layoutWindow
			else if sessionProfileName is "Stack Left" then
				set end of stackUntaggedWindows to contents of layoutWindow
			else if sessionProfileName is "Stack Laptop" then
				set end of stackLaptopUntaggedWindows to contents of layoutWindow
			end if
		end try
	end repeat
end tell

set resetCount to resetCount + (my resetDynamicLaptopAssignedWindows(quadLaptopTaggedWindows, "quad-laptop"))
set resetCount to resetCount + (my resetDynamicLaptopAssignedWindows(stackLaptopTaggedWindows, "stack-laptop"))

set quadLaptopResult to my resetUntaggedWindows(quadLaptopUntaggedWindows, "quad-laptop", quadLaptopUsedSlots)
set resetCount to resetCount + (resetCount of quadLaptopResult)
if (errorMessage of quadLaptopResult) is not "" then set end of resetErrors to errorMessage of quadLaptopResult

set quadResult to my resetUntaggedWindows(quadUntaggedWindows, "quad-left", quadUsedSlots)
set resetCount to resetCount + (resetCount of quadResult)
if (errorMessage of quadResult) is not "" then set end of resetErrors to errorMessage of quadResult

set stackResult to my resetUntaggedWindows(stackUntaggedWindows, "stack-left", stackUsedSlots)
set resetCount to resetCount + (resetCount of stackResult)
if (errorMessage of stackResult) is not "" then set end of resetErrors to errorMessage of stackResult

set stackLaptopResult to my resetUntaggedWindows(stackLaptopUntaggedWindows, "stack-laptop", stackLaptopUsedSlots)
set resetCount to resetCount + (resetCount of stackLaptopResult)
if (errorMessage of stackLaptopResult) is not "" then set end of resetErrors to errorMessage of stackLaptopResult

if (count of resetErrors) > 0 then
	error my joinMessages(resetErrors) number 1
else if resetCount is 0 then
	return "No matching iTerm layout windows found."
else
	return "Reset " & resetCount & " iTerm layout window(s)."
end if

on sessionVariable(targetSession, variableName)
	tell application id "com.googlecode.iterm2"
		tell targetSession
			try
				return variable named variableName
			on error
				return ""
			end try
		end tell
	end tell
end sessionVariable

on resetUntaggedWindows(layoutWindows, layoutName, usedSlots)
	set remainingSlots to my availableSlots(layoutName, usedSlots)
	set windowCount to count of layoutWindows

	if windowCount is 0 then return {resetCount:0, errorMessage:""}

	if windowCount > (count of remainingSlots) then
		return {resetCount:0, errorMessage:"Ambiguous " & layoutName & " reset: found " & windowCount & " untagged window(s) for " & (count of remainingSlots) & " open slot(s)."}
	end if

	set resetCount to 0
	set pendingWindows to layoutWindows
	set pendingSlots to remainingSlots
	set assignedWindows to {}

	repeat while (count of pendingWindows) > 0
		set bestWindowIndex to 0
		set bestSlotIndex to 0
		set bestDistance to missing value

		repeat with windowIndex from 1 to count of pendingWindows
			set candidateWindow to item windowIndex of pendingWindows
			set candidateBounds to my windowBounds(candidateWindow)
			set candidateCenter to my centerFor(candidateBounds)

			repeat with slotIndex from 1 to count of pendingSlots
				set candidateSlot to item slotIndex of pendingSlots
				set candidateDistance to my distanceSquared(candidateCenter, my centerFor(my boundsFor(layoutName, candidateSlot)))

				if bestDistance is missing value or candidateDistance < bestDistance then
					set bestDistance to candidateDistance
					set bestWindowIndex to windowIndex
					set bestSlotIndex to slotIndex
				end if
			end repeat
		end repeat

		set targetWindow to item bestWindowIndex of pendingWindows
		set targetSlot to item bestSlotIndex of pendingSlots
		if my isDynamicLaptopLayout(layoutName) then
			set end of assignedWindows to {windowRef:targetWindow, slotName:targetSlot}
		else
			my setWindowBounds(targetWindow, my boundsFor(layoutName, targetSlot))
		end if
		set resetCount to resetCount + 1

		set pendingWindows to my listWithoutItemAt(pendingWindows, bestWindowIndex)
		set pendingSlots to my listWithoutItemAt(pendingSlots, bestSlotIndex)
	end repeat

	if my isDynamicLaptopLayout(layoutName) then my resetDynamicLaptopAssignedWindows(assignedWindows, layoutName)

	return {resetCount:resetCount, errorMessage:""}
end resetUntaggedWindows

on resetDynamicLaptopAssignedWindows(assignedWindows, layoutName)
	if (count of assignedWindows) is 0 then return 0

	set firstAssignedWindow to item 1 of assignedWindows
	set laptopBounds to my dynamicLaptopBoundsUsing(windowRef of firstAssignedWindow, layoutName)

	repeat with assignedWindow in assignedWindows
		set assignedRecord to contents of assignedWindow
		my setWindowBounds(windowRef of assignedRecord, my dynamicLaptopSlotBounds(laptopBounds, slotName of assignedRecord))
	end repeat

	return count of assignedWindows
end resetDynamicLaptopAssignedWindows

on dynamicLaptopBoundsUsing(probeWindow, layoutName)
	if layoutName is "quad-laptop" then return my quadLaptopBoundsUsing(probeWindow)
	if layoutName is "stack-laptop" then return my stackLaptopBoundsUsing(probeWindow)

	error "Unknown dynamic laptop layout: " & layoutName number 1
end dynamicLaptopBoundsUsing

on quadLaptopBoundsUsing(probeWindow)
	set leftX to 0
	set topY to 38
	set rightX to 2056
	set bottomY to 1329

	set provisionalX2 to leftX + ((rightX - leftX) div 2)
	set seamY to topY + ((bottomY - topY) div 2)

	my setWindowBounds(probeWindow, {leftX, topY, provisionalX2, seamY})
	set topLeftBounds to my windowBounds(probeWindow)
	set safeTopY to item 2 of topLeftBounds
	set seamX to item 3 of topLeftBounds
	set seamY to item 4 of topLeftBounds

	return {topLeftBounds:topLeftBounds, topRightBounds:{seamX, safeTopY, rightX, seamY}, bottomLeftBounds:{leftX, seamY, seamX, bottomY}, bottomRightBounds:{seamX, seamY, rightX, bottomY}}
end quadLaptopBoundsUsing

on stackLaptopBoundsUsing(probeWindow)
	set leftX to 0
	set topY to 38
	set cellWidth to 1028
	set bottomY to 1329

	set x1 to leftX
	set x2 to leftX + cellWidth
	set seamY to topY + ((bottomY - topY) div 2)

	my setWindowBounds(probeWindow, {x1, topY, x2, seamY})
	set topBounds to my windowBounds(probeWindow)
	set seamY to item 4 of topBounds

	return {topBounds:topBounds, bottomBounds:{x1, seamY, x2, bottomY}}
end stackLaptopBoundsUsing

on dynamicLaptopSlotBounds(laptopBounds, slotName)
	if slotName is "top-left" then return topLeftBounds of laptopBounds
	if slotName is "top-right" then return topRightBounds of laptopBounds
	if slotName is "bottom-left" then return bottomLeftBounds of laptopBounds
	if slotName is "bottom-right" then return bottomRightBounds of laptopBounds
	if slotName is "top" then return topBounds of laptopBounds
	if slotName is "bottom" then return bottomBounds of laptopBounds

	error "Unknown dynamic laptop slot: " & slotName number 1
end dynamicLaptopSlotBounds

on isDynamicLaptopLayout(layoutName)
	if layoutName is "quad-laptop" then return true
	if layoutName is "stack-laptop" then return true
	return false
end isDynamicLaptopLayout

on availableSlots(layoutName, usedSlots)
	set expectedSlots to my slotNamesFor(layoutName)
	set remainingSlots to {}

	repeat with slotName in expectedSlots
		if not my listContains(usedSlots, contents of slotName) then set end of remainingSlots to contents of slotName
	end repeat

	return remainingSlots
end availableSlots

on isKnownSlot(layoutName, slotName)
	return my listContains(my slotNamesFor(layoutName), slotName)
end isKnownSlot

on slotNamesFor(layoutName)
	if layoutName is "quad-laptop" then return {"top-left", "top-right", "bottom-left", "bottom-right"}
	if layoutName is "quad-left" then return {"top-left", "top-right", "bottom-left", "bottom-right"}
	if layoutName is "stack-left" then return {"top", "bottom"}
	if layoutName is "stack-laptop" then return {"top", "bottom"}
	return {}
end slotNamesFor

on boundsFor(layoutName, slotName)
	if layoutName is "quad-laptop" then
		if slotName is "top-left" then return {0, 38, 1028, 683}
		if slotName is "top-right" then return {1028, 38, 2056, 683}
		if slotName is "bottom-left" then return {0, 683, 1028, 1329}
		if slotName is "bottom-right" then return {1028, 683, 2056, 1329}
	else if layoutName is "quad-left" then
		if slotName is "top-left" then return {0, 0, 1280, 720}
		if slotName is "top-right" then return {1280, 0, 2560, 720}
		if slotName is "bottom-left" then return {0, 720, 1280, 1440}
		if slotName is "bottom-right" then return {1280, 720, 2560, 1440}
	else if layoutName is "stack-left" then
		if slotName is "top" then return {0, 0, 1280, 720}
		if slotName is "bottom" then return {0, 720, 1280, 1440}
	else if layoutName is "stack-laptop" then
		if slotName is "top" then return {0, 38, 1028, 683}
		if slotName is "bottom" then return {0, 683, 1028, 1329}
	end if

	error "Unknown iTerm layout slot: " & layoutName & " " & slotName number 1
end boundsFor

on centerFor(windowBounds)
	set centerX to ((item 1 of windowBounds) + (item 3 of windowBounds)) / 2
	set centerY to ((item 2 of windowBounds) + (item 4 of windowBounds)) / 2
	return {centerX, centerY}
end centerFor

on distanceSquared(firstPoint, secondPoint)
	set deltaX to (item 1 of firstPoint) - (item 1 of secondPoint)
	set deltaY to (item 2 of firstPoint) - (item 2 of secondPoint)
	return (deltaX * deltaX) + (deltaY * deltaY)
end distanceSquared

on windowBounds(targetWindow)
	tell application id "com.googlecode.iterm2"
		return bounds of targetWindow
	end tell
end windowBounds

on setWindowBounds(targetWindow, targetBounds)
	tell application id "com.googlecode.iterm2"
		set bounds of targetWindow to targetBounds
	end tell
end setWindowBounds

on addSlotIfMissing(slotList, slotName)
	if not my listContains(slotList, slotName) then set end of slotList to slotName
	return slotList
end addSlotIfMissing

on listContains(theList, targetValue)
	repeat with listValue in theList
		if contents of listValue is targetValue then return true
	end repeat

	return false
end listContains

on listWithoutItemAt(theList, itemIndex)
	set newList to {}

	repeat with currentIndex from 1 to count of theList
		if currentIndex is not itemIndex then set end of newList to item currentIndex of theList
	end repeat

	return newList
end listWithoutItemAt

on joinMessages(messages)
	set oldDelimiters to AppleScript's text item delimiters
	set AppleScript's text item delimiters to linefeed
	set joinedMessages to messages as text
	set AppleScript's text item delimiters to oldDelimiters
	return joinedMessages
end joinMessages
APPLESCRIPT
