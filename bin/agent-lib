#!/usr/bin/env bash

AGENT_NODE_ROOT="${AGENT_NODE_ROOT:-$HOME/Documents/Coding/node}"
AGENT_WORKTREE_ROOT="${AGENT_WORKTREE_ROOT:-$AGENT_NODE_ROOT/_agent-worktrees}"
AGENT_REGISTRY_DIR="${AGENT_REGISTRY_DIR:-$AGENT_WORKTREE_ROOT/_registry}"

agent_die() {
  printf 'agent: %s\n' "$*" >&2
  exit 1
}

agent_timestamp() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

agent_ensure_registry() {
  mkdir -p "$AGENT_REGISTRY_DIR" "$AGENT_REGISTRY_DIR/reviews" "$AGENT_REGISTRY_DIR/archive"
}

agent_resolve_repo() {
  local repo_arg="$1"
  local candidate

  if [[ "$repo_arg" = /* ]]; then
    candidate="$repo_arg"
  else
    candidate="$AGENT_NODE_ROOT/$repo_arg"
  fi

  [[ -d "$candidate" ]] || agent_die "repo not found: $repo_arg"
  git -C "$candidate" rev-parse --show-toplevel 2>/dev/null || agent_die "not a git repo: $candidate"
}

agent_valid_state() {
  case "$1" in
    queued|running|needs-input|review|merged|abandoned) return 0 ;;
    *) return 1 ;;
  esac
}

agent_kv() {
  local key="$1"
  local value="${2-}"
  printf '%s=%q\n' "$key" "$value"
}

agent_find_task_file() {
  local query="$1"
  local matches=()

  agent_ensure_registry

  if [[ -f "$query" ]]; then
    printf '%s\n' "$query"
    return 0
  fi

  if [[ -f "$AGENT_REGISTRY_DIR/$query.env" ]]; then
    printf '%s\n' "$AGENT_REGISTRY_DIR/$query.env"
    return 0
  fi

  shopt -s nullglob
  matches=( "$AGENT_REGISTRY_DIR"/*"$query"*.env )
  shopt -u nullglob

  case "${#matches[@]}" in
    0) agent_die "task not found: $query" ;;
    1) printf '%s\n' "${matches[0]}" ;;
    *)
      printf 'agent: task query is ambiguous: %s\n' "$query" >&2
      printf '  %s\n' "${matches[@]}" >&2
      exit 1
      ;;
  esac
}

agent_load_task() {
  local file="$1"
  # shellcheck disable=SC1090
  source "$file"
}

agent_write_task_file() {
  local file="$1"
  local tmp
  tmp="$(mktemp "$AGENT_REGISTRY_DIR/.task.XXXXXX")"

  {
    agent_kv task_id "${task_id-}"
    agent_kv repo_name "${repo_name-}"
    agent_kv repo_path "${repo_path-}"
    agent_kv worktree_path "${worktree_path-}"
    agent_kv branch "${branch-}"
    agent_kv base_ref "${base_ref:-main}"
    agent_kv state "${state-}"
    agent_kv created_at "${created_at-}"
    agent_kv updated_at "${updated_at-}"
    agent_kv prompt "${prompt-}"
    agent_kv note "${note-}"
    agent_kv review_artifact "${review_artifact-}"
    agent_kv check_exit "${check_exit-}"
    agent_kv review_exit "${review_exit-}"
    agent_kv tmux_session "${tmux_session-}"
    agent_kv tmux_window "${tmux_window-}"
    agent_kv cleaned_at "${cleaned_at-}"
  } > "$tmp"

  chmod 600 "$tmp"
  mv "$tmp" "$file"
}

agent_trunc() {
  local value="${1-}"
  local width="$2"
  if (( ${#value} > width )); then
    printf '%s~' "${value:0:$((width - 1))}"
  else
    printf '%s' "$value"
  fi
}

agent_diff_summary() {
  local worktree="$1"
  local base="${2:-main}"
  local commits="?"
  local changed="?"

  if [[ ! -d "$worktree" ]]; then
    printf 'missing worktree'
    return 0
  fi

  commits="$(git -C "$worktree" rev-list --count "$base"..HEAD 2>/dev/null || printf '?')"
  changed="$(git -C "$worktree" status --short 2>/dev/null | wc -l)"
  changed="${changed//[[:space:]]/}"

  if [[ "$commits" = "0" && "$changed" = "0" ]]; then
    printf 'clean'
  else
    printf '%s commits, %s worktree changes' "$commits" "$changed"
  fi
}

agent_next_action() {
  local state="$1"
  local check="${2-}"
  local review="${3-}"

  case "$state" in
    queued) printf 'start agent or mark running' ;;
    running) printf 'monitor tmux/status' ;;
    needs-input) printf 'inspect task and unblock' ;;
    review)
      if [[ "$check" = "0" && "$review" = "0" ]]; then
        printf 'human diff review'
      else
        printf 'inspect review/check failures'
      fi
      ;;
    merged|abandoned) printf 'agent-clean task' ;;
    *) printf 'inspect registry' ;;
  esac
}

agent_check_command() {
  local repo_name_arg="$1"
  local worktree="$2"

  if [[ -n "${AGENT_CHECK_COMMAND:-}" ]]; then
    printf '%s\n' "$AGENT_CHECK_COMMAND"
    return 0
  fi

  case "$repo_name_arg" in
    node_account|node_website|node_ux|node_email)
      printf 'npm run check\n'
      ;;
    *)
      if [[ -f "$worktree/package.json" ]] && grep -q '"check"' "$worktree/package.json"; then
        printf 'npm run check\n'
      else
        printf '\n'
      fi
      ;;
  esac
}

agent_build_env() {
  AGENT_ENV=(env)

  if [[ "${AGENT_INHERIT_SECRETS:-0}" = "1" ]]; then
    return 0
  fi

  AGENT_ENV+=(
    -u CLOUDFLARE_API_TOKEN
    -u CLOUDFLARE_ACCOUNT_ID
    -u CF_API_TOKEN
    -u HOME_ASSISTANT_TOKEN
    -u GITHUB_TOKEN
    -u GH_TOKEN
    -u NPM_TOKEN
    -u OPENAI_API_KEY
    -u ANTHROPIC_API_KEY
    -u AWS_ACCESS_KEY_ID
    -u AWS_SECRET_ACCESS_KEY
    -u AWS_SESSION_TOKEN
    -u GOOGLE_APPLICATION_CREDENTIALS
  )
}

agent_confirm() {
  local prompt="$1"
  local answer
  printf '%s [y/N] ' "$prompt" >&2
  read -r answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

agent_confirm_exact() {
  local expected="$1"
  local prompt="$2"
  local answer
  printf '%s\nType "%s" to continue: ' "$prompt" "$expected" >&2
  read -r answer
  [[ "$answer" = "$expected" ]]
}

