#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=agent-lib
source "$script_dir/agent-lib"

usage() {
  printf 'Usage: agent-review <task>\n' >&2
  exit 2
}

[[ $# -eq 1 ]] || usage

task_query="$1"
task_file="$(agent_find_task_file "$task_query")"
agent_load_task "$task_file"

[[ -d "${worktree_path:-}" ]] || agent_die "worktree not found: ${worktree_path:-unknown}"
command -v codex >/dev/null 2>&1 || agent_die "codex is required"
codex_bin="$(command -v codex)"

agent_ensure_registry

base_ref="${base_ref:-main}"
check_cmd="$(agent_check_command "${repo_name:-$(basename "${repo_path:-}")}" "$worktree_path")"
review_stamp="$(date '+%Y%m%d-%H%M%S')"
review_artifact="$AGENT_REGISTRY_DIR/reviews/${task_id}-${review_stamp}.md"
check_exit=0
review_exit=0

{
  printf '# Agent Review: %s\n\n' "$task_id"
  printf -- '- Repo: `%s`\n' "${repo_name:-unknown}"
  printf -- '- Branch: `%s`\n' "${branch:-unknown}"
  printf -- '- Worktree: `%s`\n' "$worktree_path"
  printf -- '- Base: `%s`\n' "$base_ref"
  printf -- '- Started: `%s`\n\n' "$(agent_timestamp)"
  printf '## Diff Stat\n\n'
  printf 'Committed branch diff:\n\n'
  printf '```text\n'
  git -C "$worktree_path" diff --stat "$base_ref"...HEAD 2>&1 || true
  printf '```\n\n'
  printf 'Uncommitted diff:\n\n'
  printf '```text\n'
  git -C "$worktree_path" diff --stat 2>&1 || true
  printf '```\n\n'
  printf '## Repo Check\n\n'
} > "$review_artifact"

if [[ -n "$check_cmd" ]]; then
  {
    printf 'Command: `%s`\n\n' "$check_cmd"
    printf '```text\n'
  } >> "$review_artifact"
  set +e
  (cd "$worktree_path" && eval "$check_cmd") >> "$review_artifact" 2>&1
  check_exit=$?
  set -e
  {
    printf '```\n\n'
    printf 'Exit: `%s`\n\n' "$check_exit"
  } >> "$review_artifact"
else
  {
    printf 'No check command found for this repo.\n\n'
  } >> "$review_artifact"
fi

{
  printf '## Codex Review\n\n'
  printf 'Command: `codex review --uncommitted`\n\n'
  printf '```text\n'
} >> "$review_artifact"

agent_build_env

set +e
(cd "$worktree_path" && "${AGENT_ENV[@]}" "$codex_bin" review --uncommitted) >> "$review_artifact" 2>&1
review_exit=$?
set -e

{
  printf '```\n\n'
  printf 'Exit: `%s`\n' "$review_exit"
} >> "$review_artifact"

updated_at="$(agent_timestamp)"
if [[ "$check_exit" = "0" && "$review_exit" = "0" ]]; then
  state="review"
  note="Review artifact ready"
else
  state="needs-input"
  note="Review or check failed; inspect artifact"
fi

agent_write_task_file "$task_file"

printf 'Review artifact: %s\n' "$review_artifact"
printf 'Check exit: %s\n' "$check_exit"
printf 'Codex review exit: %s\n' "$review_exit"
printf 'State: %s\n' "$state"

if [[ "$check_exit" != "0" || "$review_exit" != "0" ]]; then
  exit 1
fi

