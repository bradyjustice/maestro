#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=agent-lib
source "$script_dir/agent-lib"

usage() {
  printf 'Usage: agent-clean [--force] <task>\n' >&2
  exit 2
}

force=0
if [[ "${1:-}" = "--force" ]]; then
  force=1
  shift
fi

[[ $# -eq 1 ]] || usage

task_query="$1"
task_file="$(agent_find_task_file "$task_query")"
agent_load_task "$task_file"

case "${state:-}" in
  merged|abandoned) ;;
  *)
    if (( force == 0 )); then
      agent_die "refusing to clean task in state '${state:-unknown}'. Mark merged/abandoned first or rerun with --force."
    fi
    ;;
esac

dirty=""
if [[ -d "${worktree_path:-}" ]]; then
  dirty="$(git -C "$worktree_path" status --porcelain 2>/dev/null || true)"
fi

if [[ -n "$dirty" && "$force" = "0" ]]; then
  agent_die "refusing to remove dirty worktree. Review changes or rerun with --force for an explicit destructive cleanup."
fi

if [[ -n "$dirty" || "$force" = "1" ]]; then
  agent_confirm_exact "remove ${task_id}" "This can discard local worktree changes for ${task_id}." || agent_die "aborted"
else
  agent_confirm "Remove clean worktree for ${task_id}?" || agent_die "aborted"
fi

if [[ -d "${worktree_path:-}" ]]; then
  if (( force == 1 )); then
    git -C "$repo_path" worktree remove --force "$worktree_path"
  else
    git -C "$repo_path" worktree remove "$worktree_path"
  fi
else
  printf 'agent: worktree already missing: %s\n' "${worktree_path:-unknown}" >&2
fi

updated_at="$(agent_timestamp)"
cleaned_at="$updated_at"
note="${note:-Cleaned by agent-clean}"
agent_write_task_file "$task_file"

archive_file="$AGENT_REGISTRY_DIR/archive/$(basename "$task_file")"
mv "$task_file" "$archive_file"

printf 'Archived registry: %s\n' "$archive_file"

