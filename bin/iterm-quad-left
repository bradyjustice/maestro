#!/bin/zsh
set -euo pipefail

osascript <<'APPLESCRIPT'
set profileName to "Quad Left"

set leftX to 0
set topY to 0
set cellWidth to 1280
set cellHeight to 720

set x1 to leftX
set x2 to leftX + cellWidth
set x3 to leftX + (cellWidth * 2)
set y1 to topY
set y2 to topY + cellHeight
set y3 to topY + (cellHeight * 2)

tell application id "com.googlecode.iterm2"
	set topLeftWindow to (create window with profile profileName)
	set bounds of topLeftWindow to {x1, y1, x2, y2}
	my tagWindow(topLeftWindow, "top-left")

	set topRightWindow to (create window with profile profileName)
	set bounds of topRightWindow to {x2, y1, x3, y2}
	my tagWindow(topRightWindow, "top-right")

	set bottomLeftWindow to (create window with profile profileName)
	set bounds of bottomLeftWindow to {x1, y2, x2, y3}
	my tagWindow(bottomLeftWindow, "bottom-left")

	set bottomRightWindow to (create window with profile profileName)
	set bounds of bottomRightWindow to {x2, y2, x3, y3}
	my tagWindow(bottomRightWindow, "bottom-right")

	activate
end tell

on tagWindow(targetWindow, slotName)
	tell application id "com.googlecode.iterm2"
		try
			tell current session of targetWindow
				set variable named "user.localToolsLayout" to "quad-left"
				set variable named "user.localToolsSlot" to slotName
			end tell
		end try
	end tell
end tagWindow
APPLESCRIPT
