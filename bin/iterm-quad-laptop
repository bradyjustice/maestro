#!/bin/zsh
set -euo pipefail

osascript <<'APPLESCRIPT'
set profileName to "Quad Laptop"

set leftX to 0
set topY to 38
set rightX to 2056
set bottomY to 1329

set provisionalX2 to leftX + ((rightX - leftX) div 2)
set seamY to topY + ((bottomY - topY) div 2)

tell application id "com.googlecode.iterm2"
	set topLeftWindow to (create window with profile profileName)
	set bounds of topLeftWindow to {leftX, topY, provisionalX2, seamY}

	set topLeftBounds to bounds of topLeftWindow
	set safeTopY to item 2 of topLeftBounds
	set seamX to item 3 of topLeftBounds
	set seamY to item 4 of topLeftBounds
	my tagWindow(topLeftWindow, "top-left")

	set topRightWindow to (create window with profile profileName)
	set bounds of topRightWindow to {seamX, safeTopY, rightX, seamY}
	my tagWindow(topRightWindow, "top-right")

	set bottomLeftWindow to (create window with profile profileName)
	set bounds of bottomLeftWindow to {leftX, seamY, seamX, bottomY}
	my tagWindow(bottomLeftWindow, "bottom-left")

	set bottomRightWindow to (create window with profile profileName)
	set bounds of bottomRightWindow to {seamX, seamY, rightX, bottomY}
	my tagWindow(bottomRightWindow, "bottom-right")

	activate
end tell

on tagWindow(targetWindow, slotName)
	tell application id "com.googlecode.iterm2"
		try
			tell current session of targetWindow
				set variable named "user.localToolsLayout" to "quad-laptop"
				set variable named "user.localToolsSlot" to slotName
			end tell
		end try
	end tell
end tagWindow
APPLESCRIPT
