#!/bin/zsh
set -euo pipefail

osascript <<'APPLESCRIPT'
set profileName to "Stack Laptop"

set leftX to 0
set topY to 38
set cellWidth to 1028
set bottomY to 1329

set x1 to leftX
set x2 to leftX + cellWidth
set y1 to topY
set seamY to topY + ((bottomY - topY) div 2)

tell application id "com.googlecode.iterm2"
	set topWindow to (create window with profile profileName)
	set bounds of topWindow to {x1, y1, x2, seamY}

	set topWindowBounds to bounds of topWindow
	set seamY to item 4 of topWindowBounds
	my tagWindow(topWindow, "top")

	set bottomWindow to (create window with profile profileName)
	set bounds of bottomWindow to {x1, seamY, x2, bottomY}
	my tagWindow(bottomWindow, "bottom")

	activate
end tell

on tagWindow(targetWindow, slotName)
	tell application id "com.googlecode.iterm2"
		try
			tell current session of targetWindow
				set variable named "user.localToolsLayout" to "stack-laptop"
				set variable named "user.localToolsSlot" to slotName
			end tell
		end try
	end tell
end tagWindow
APPLESCRIPT
