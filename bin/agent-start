#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=agent-lib
source "$script_dir/agent-lib"

usage() {
  printf 'Usage: agent-start <repo|repo-path> <task-slug> [prompt]\n' >&2
  exit 2
}

[[ $# -ge 2 ]] || usage

repo_arg="$1"
task_slug="$2"
shift 2
prompt="$*"

if [[ ! "$task_slug" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
  agent_die "task slug must use letters, numbers, dots, underscores, or hyphens"
fi

command -v git >/dev/null 2>&1 || agent_die "git is required"

if [[ "${AGENT_START_NO_LAUNCH:-0}" != "1" ]]; then
  command -v tmux >/dev/null 2>&1 || agent_die "tmux is required"
  command -v codex >/dev/null 2>&1 || agent_die "codex is required"
  codex_bin="$(command -v codex)"
else
  codex_bin=""
fi

agent_ensure_registry

repo_path="$(agent_resolve_repo "$repo_arg")"
repo_name="$(basename "$repo_path")"
base_ref="${AGENT_BASE_REF:-main}"
date_slug="$(date '+%Y%m%d')"
branch="agent/${date_slug}-${task_slug}"
task_id="${repo_name}-${date_slug}-${task_slug}"
worktree_path="$AGENT_WORKTREE_ROOT/$task_id"
registry_file="$AGENT_REGISTRY_DIR/$task_id.env"
created_at="$(agent_timestamp)"
updated_at="$created_at"
state="running"
note="Started by agent-start"
review_artifact=""
check_exit=""
review_exit=""
tmux_session="${AGENT_TMUX_SESSION:-agents}"
tmux_window="agent:${task_slug} - running - ${branch#agent/}"
cleaned_at=""

git -C "$repo_path" rev-parse --verify "$base_ref^{commit}" >/dev/null 2>&1 || agent_die "base ref not found in $repo_name: $base_ref"
git -C "$repo_path" show-ref --verify --quiet "refs/heads/$branch" && agent_die "branch already exists: $branch"
[[ ! -e "$worktree_path" ]] || agent_die "worktree path already exists: $worktree_path"
[[ ! -f "$registry_file" ]] || agent_die "registry entry already exists: $registry_file"

source_status="$(git -C "$repo_path" status --short)"
if [[ -n "$source_status" ]]; then
  printf 'agent: warning: source checkout has uncommitted changes; new worktree still starts from %s\n' "$base_ref" >&2
fi

git -C "$repo_path" worktree add -b "$branch" "$worktree_path" "$base_ref"

if [[ "${AGENT_START_NO_LAUNCH:-0}" = "1" ]]; then
  state="queued"
  note="Worktree created; launch skipped by AGENT_START_NO_LAUNCH"
  tmux_window=""
  agent_write_task_file "$registry_file"
else
  agent_write_task_file "$registry_file"
  agent_build_env
  cmd=( "${AGENT_ENV[@]}" "$codex_bin" --cd "$worktree_path" --sandbox workspace-write --ask-for-approval on-request )
  if [[ -n "$prompt" ]]; then
    cmd+=( "$prompt" )
  fi
  cmd_string="$(printf '%q ' "${cmd[@]}")"

  if [[ -n "${TMUX:-}" ]]; then
    tmux new-window -n "$tmux_window" -c "$worktree_path" "$cmd_string"
  else
    if ! tmux has-session -t "$tmux_session" 2>/dev/null; then
      tmux new-session -d -s "$tmux_session" -n agent-status "$script_dir/agent-status; exec \$SHELL -l"
    fi
    tmux new-window -t "$tmux_session:" -n "$tmux_window" -c "$worktree_path" "$cmd_string"
  fi
fi

printf 'Task: %s\n' "$task_id"
printf 'Repo: %s\n' "$repo_path"
printf 'Branch: %s\n' "$branch"
printf 'Worktree: %s\n' "$worktree_path"
printf 'Registry: %s\n' "$registry_file"
if [[ "${AGENT_START_NO_LAUNCH:-0}" = "1" ]]; then
  printf 'Launch: skipped by AGENT_START_NO_LAUNCH\n'
else
  printf 'tmux: %s / %s\n' "$tmux_session" "$tmux_window"
fi

